# Code Audit (read-only GitHub — Tech Department + Mayor GitHub tools)
GITHUB_TOKEN=
GITHUB_REPO=offsam/aicouncil
GITHUB_REF=main
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# Internal API shared secret (X-Internal-Secret header for protected server routes)
